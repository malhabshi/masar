rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isUserAdmin() {
      return getUserData().role == 'admin';
    }
    
    function isDepartment() {
      return getUserData().role == 'department';
    }

    // Students documents - only assigned employee or admin/dept can access
    match /students/{studentId}/{fileName} {
      allow read, write: if request.auth != null && (
        isUserAdmin() || isDepartment() ||
        get(/databases/$(database)/documents/students/$(studentId)).data.employeeId == getUserData().civilId
      );
    }

    // Shared documents - admin/dept can write, all authenticated can read.
    match /shared_documents/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isUserAdmin() || isDepartment());
    }

  }
}
