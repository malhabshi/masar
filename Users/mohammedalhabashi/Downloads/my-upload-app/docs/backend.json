
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents an individual user within the UniApply Hub system.",
      "properties": {
        "name": { "type": "string", "description": "The full name of the user." },
        "email": { "type": "string", "description": "The email address of the user.", "format": "email" },
        "phone": { "type": "string", "description": "The phone number of the user." },
        "role": { "type": "string", "description": "The role of the user within the system.", "enum": ["admin", "employee", "department"] },
        "civilId": { "type": "string", "description": "The user's Civil ID number." },
        "employeeId": { "type": "string", "description": "A shorter, derived employee ID." },
        "avatarUrl": { "type": "string", "description": "URL to the user's avatar image.", "format": "uri" }
      },
      "required": ["name", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Represents a student applicant being managed by the agency.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the student." },
        "name": { "type": "string", "description": "The full name of the student." },
        "email": { "type": "string", "description": "The email address of the student.", "format": "email" },
        "phone": { "type": "string", "description": "The phone number of the student." },
        "employeeId": { "type": "string", "description": "The Civil ID of the employee assigned to this student." },
        "avatarUrl": { "type": "string", "description": "URL to the student's avatar image.", "format": "uri" },
        "applications": { "type": "array", "items": { "$ref": "#/entities/Application" } },
        "notes": { "type": "array", "items": { "$ref": "#/entities/Note" } },
        "documents": { "type": "array", "items": { "$ref": "#/entities/Document" } },
        "createdAt": { "type": "string", "description": "Timestamp when the student was created.", "format": "date-time" },
        "createdBy": { "type": "string", "description": "The ID of the user who created the student." },
        "targetCountries": { "type": "array", "items": { "type": "string" } },
        "missingItems": { "type": "array", "items": { "type": "string" } },
        "pipelineStatus": { "type": "string", "enum": ["green", "orange", "red", "none"] },
        "transferHistory": { "type": "array", "items": { "$ref": "#/entities/StudentTransfer" } },
        "unreadUpdates": { "type": "number", "description": "Counter for unread updates for admin/dept." },
        "employeeUnreadMessages": { "type": "number", "description": "Counter for unread chat messages for the employee." },
        "newDocumentsForEmployee": { "type": "number" },
        "newDocumentsForAdmin": { "type": "number" },
        "newMissingItemsForEmployee": { "type": "number" },
        "finalChoiceUniversity": { "type": "string" },
        "ielts": { "$ref": "#/entities/IeltsScore" },
        "profileCompletionStatus": { "$ref": "#/entities/ProfileCompletionStatus" },
        "transferRequested": { "type": "boolean" },
        "deletionRequested": { "type": "boolean" },
        "isNewForEmployee": { "type": "boolean" },
        "term": { "type": "string" }
      },
      "required": ["id", "name", "email", "phone", "createdAt"]
    },
    "Application": {
      "title": "Application",
      "type": "object",
      "description": "Represents a university application for a student.",
      "properties": {
        "university": { "type": "string" },
        "major": { "type": "string" },
        "country": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Submitted", "In Review", "Accepted", "Rejected"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["university", "major", "country", "status", "updatedAt"]
    },
    "Note": {
      "title": "Note",
      "type": "object",
      "description": "A note or comment about a student.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorId", "content", "createdAt"]
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "description": "Represents a file uploaded for a student.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "isNew": { "type": "boolean" }
      },
      "required": ["id", "name", "url", "uploadedAt", "authorId"]
    },
    "IeltsScore": {
      "title": "IELTS Score",
      "type": "object",
      "properties": {
        "overall": { "type": "number" },
        "listening": { "type": "number" },
        "reading": { "type": "number" },
        "writing": { "type": "number" },
        "speaking": { "type": "number" },
        "uploadedDocumentId": { "type": "string" }
      }
    },
    "ProfileCompletionStatus": {
      "title": "Profile Completion Status",
      "type": "object",
      "properties": {
        "submitUniversityApplication": { "type": "boolean" },
        "applyMoheScholarship": { "type": "boolean" },
        "submitKcoRequest": { "type": "boolean" },
        "receivedCasOrI20": { "type": "boolean" },
        "appliedForVisa": { "type": "boolean" },
        "documentsSubmittedToMohe": { "type": "boolean" },
        "readyToTravel": { "type": "boolean" }
      }
    },
    "StudentTransfer": {
      "title": "Student Transfer",
      "type": "object",
      "properties": {
        "fromEmployeeId": { "type": "string" },
        "toEmployeeId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "transferredBy": { "type": "string" }
      }
    },
    "ChatMessage": {
      "title": "Chat Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "document": { "type": "object", "properties": { "name": { "type": "string" }, "url": { "type": "string" } } }
      },
      "required": ["id", "authorId", "content", "timestamp"]
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "recipientId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "in-progress", "completed", "archived"] },
        "replies": { "type": "array", "items": { "$ref": "#/entities/TaskReply" } }
      },
      "required": ["id", "authorId", "recipientId", "content", "status", "createdAt"]
    },
    "TaskReply": {
      "title": "Task Reply",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorId", "content", "createdAt"]
    },
    "ApplicationQuestion": {
      "title": "Application Question",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "questionText": { "type": "string" },
        "questionType": { "type": "string", "enum": ["text", "textarea", "number", "date", "select", "checkbox"] },
        "options": { "type": "array", "items": { "type": "string" } },
        "isRequired": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "sortOrder": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "questionText", "questionType", "isRequired", "isActive", "createdAt"]
    },
    "UpcomingEvent": {
      "title": "Upcoming Event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "date", "authorId"]
    },
    "SharedDocument": {
      "title": "Shared Document",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "country": { "type": "string" }
      },
      "required": ["name", "url", "uploadedAt", "authorId"]
    },
    "RequestType": {
      "title": "Request Type",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "defaultRecipientId": { "type": "string" }
      },
      "required": ["name", "description", "defaultRecipientId"]
    },
    "PersonalTodo": {
      "title": "Personal Todo",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "completed", "createdAt"]
    },
    "ResourceLink": {
      "title": "Resource Link",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url", "authorId", "createdAt"]
    },
    "TimeLog": {
      "title": "Time Log",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "clockIn": { "type": "string", "format": "date-time" },
        "clockOut": { "type": "string", "format": "date-time" }
      },
      "required": ["employeeId", "date", "clockIn", "clockOut"]
    },
    "ApprovedUniversity": {
      "title": "Approved University",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "major": { "type": "string" },
        "country": { "type": "string" },
        "ieltsScore": { "type": "number" },
        "isAvailable": { "type": "boolean" }
      },
      "required": ["id", "name", "major", "country", "ieltsScore", "isAvailable"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/entities/User" }, "description": "Stores individual user profiles." },
    "/users/{userId}/personal_todos/{todoId}": { "schema": { "$ref": "#/entities/PersonalTodo" } },
    "/students/{studentId}": { "schema": { "$ref": "#/entities/Student" } },
    "/approved_universities/{universityId}": { "schema": { "$ref": "#/entities/ApprovedUniversity" } },
    "/application_questions/{questionId}": { "schema": { "$ref": "#/entities/ApplicationQuestion" } },
    "/tasks/{taskId}": { "schema": { "$ref": "#/entities/Task" } },
    "/chats/{studentId}/messages/{messageId}": { "schema": { "$ref": "#/entities/ChatMessage" } },
    "/upcoming_events/{eventId}": { "schema": { "$ref": "#/entities/UpcomingEvent" } },
    "/shared_documents/{documentId}": { "schema": { "$ref": "#/entities/SharedDocument" } },
    "/request_types/{requestTypeId}": { "schema": { "$ref": "#/entities/RequestType" } },
    "/resource_links/{linkId}": { "schema": { "$ref": "#/entities/ResourceLink" } },
    "/time_logs/{logId}": { "schema": { "$ref": "#/entities/TimeLog" } }
  }
}
