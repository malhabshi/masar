{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user within the UniApply Hub system, either an employee or an administrator. This entity stores core user information and their role.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The full name of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user, used for identification and communication.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the user, potentially used for WhatsApp notifications."
        },
        "role": {
          "type": "string",
          "description": "The role of the user within the system (e.g., 'admin', 'employee')."
        },
        "civilId": {
            "type": "string"
        },
        "employeeId": {
            "type": "string"
        },
        "avatarUrl": {
            "type": "string",
            "format": "uri"
        }
      },
      "required": [
        "name",
        "email",
        "role"
      ]
    },
    "Student": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Student",
      "type": "object",
      "description": "Represents a student whose university applications are being managed through the UniApply Hub by an employee.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Student entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the student."
        },
        "email": {
          "type": "string",
          "description": "The email address of the student, used for communication and detecting shared students.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the student, used for communication and detecting shared students."
        },
        "nationality": {
          "type": "string",
          "description": "The nationality of the student."
        },
        "dateOfBirth": {
          "type": "string",
          "description": "The student's date of birth.",
          "format": "date"
        },
        "employeeId": {
          "type": "string",
          "description": "Reference to the User (employee) who is assigned to manage this student's applications. This is the employee's Civil ID."
        },
        "notes": {
          "type": "array",
          "description": "A list of notes (objects with id, authorId, content, createdAt) about the student.",
          "items": {
              "type": "object"
          }
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the student record was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the student record was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "phone",
        "createdAt"
      ]
    },
    "University": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "University",
      "type": "object",
      "description": "Represents a university to which students can apply through the UniApply Hub.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the University entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the university."
        },
        "country": {
          "type": "string",
          "description": "The country where the university is located (e.g., UK, USA, Australia, New Zealand)."
        }
      },
      "required": [
        "id",
        "name",
        "country"
      ]
    },
    "Application": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Application",
      "type": "object",
      "description": "Represents a specific university application submitted on behalf of a student, tracking its status and details.",
      "properties": {
        "university": {
          "type": "string"
        },
        "major": {
          "type": "string"
        },
        "country": {
            "type": "string"
        },
        "status": {
          "type": "string",
          "description": "The current status of the application (e.g., 'Pending', 'Submitted', 'In Review', 'Accepted', 'Rejected')."
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the application record was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "university",
        "major",
        "country",
        "status",
        "updatedAt"
      ]
    },
    "Document": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Document",
      "type": "object",
      "description": "Represents a document uploaded by an employee or admin for a student.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "uploadedAt": {
          "type": "string",
          "format": "date-time"
        },
        "authorId": {
          "type": "string"
        },
        "isNew": {
            "type": "boolean"
        }
      },
      "required": [
        "id",
        "name",
        "url",
        "uploadedAt",
        "authorId"
      ]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a specific task related to a student's application process, typically assigned by an admin to an employee.",
      "properties": {
        "id": {
          "type": "string"
        },
        "authorId": {
          "type": "string"
        },
        "recipientId": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "The current status of the task (e.g., 'new', 'in-progress', 'completed', 'archived')."
        },
        "replies": {
            "type": "array"
        }
      },
      "required": [
        "id",
        "authorId",
        "recipientId",
        "content",
        "status",
        "createdAt"
      ]
    },
    "ChatMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChatMessage",
      "type": "object",
      "description": "Represents a message exchanged within the real-time chatbot between an employee and an admin regarding a specific student's application.",
      "properties": {
        "id": {
          "type": "string"
        },
        "authorId": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "authorId",
        "content",
        "timestamp"
      ]
    },
    "ApplicationQuestion": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ApplicationQuestion",
      "type": "object",
      "description": "Represents a customizable question that an admin can define to be part of the student application forms.",
      "properties": {
        "id": {
          "type": "string"
        },
        "questionText": {
          "type": "string"
        },
        "questionType": {
          "type": "string"
        },
        "isRequired": {
          "type": "boolean"
        },
        "isActive": {
          "type": "boolean"
        },
        "sortOrder": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "questionText",
        "questionType",
        "isRequired",
        "isActive",
        "createdAt"
      ]
    },
    "UpcomingEvent": {
      "title": "Upcoming Event",
      "type": "object",
      "description": "Represents an upcoming event for all users.",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "date", "authorId"]
    },
    "SharedDocument": {
      "title": "Shared Document",
      "type": "object",
      "description": "Represents a document shared with all users.",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "country": { "type": "string" }
      },
      "required": ["name", "url", "uploadedAt", "authorId"]
    },
    "RequestType": {
      "title": "Request Type",
      "type": "object",
      "description": "Defines a type of request an employee can make.",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "defaultRecipientId": { "type": "string" }
      },
      "required": ["name", "description", "defaultRecipientId"]
    },
    "PersonalTodo": {
      "title": "Personal Todo",
      "type": "object",
      "description": "A personal to-do item for a user.",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "completed", "createdAt"]
    },
    "ResourceLink": {
      "title": "Resource Link",
      "type": "object",
      "description": "Represents a helpful external link shared with all users.",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url", "authorId", "createdAt"]
    },
    "TimeLog": {
      "title": "Time Log",
      "type": "object",
      "description": "Represents a single clock-in/clock-out session for an employee.",
      "properties": {
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "clockIn": { "type": "string", "format": "date-time" },
        "clockOut": { "type": "string", "format": "date-time" }
      },
      "required": ["employeeId", "date", "clockIn", "clockOut"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores individual user profiles (employees and admins). The 'role' field is the source of truth for permissions."
    },
    "/users/{userId}/personal_todos/{todoId}": {
      "schema": { "$ref": "#/entities/PersonalTodo" }
    },
    "/students/{studentId}": {
      "schema": { "$ref": "#/entities/Student" }
    },
    "/approved_universities/{universityId}": {
      "schema": { "$ref": "#/entities/University" }
    },
    "/application_questions/{questionId}": {
      "schema": { "$ref": "#/entities/ApplicationQuestion" }
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" }
    },
    "/chats/{studentId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" }
    },
    "/upcoming_events/{eventId}": {
      "schema": { "$ref": "#/entities/UpcomingEvent" }
    },
    "/shared_documents/{documentId}": {
      "schema": { "$ref": "#/entities/SharedDocument" }
    },
    "/request_types/{requestTypeId}": {
      "schema": { "$ref": "#/entities/RequestType" }
    },
    "/resource_links/{linkId}": {
      "schema": { "$ref": "#/entities/ResourceLink" }
    },
    "/time_logs/{logId}": {
      "schema": { "$ref": "#/entities/TimeLog" }
    }
  }
}
