
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isUserAdmin() {
      return getUserData().role == 'admin';
    }
    
    function isDepartment() {
      return getUserData().role == 'department';
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isUserAdmin() || (isOwner(userId) && (request.resource.data.role != 'admin' || request.resource.data.email == 'admin@uniapply.hub'));
      allow update: if isUserAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isUserAdmin();
    }

    match /students/{studentId} {
      // Admins and departments can read any student.
      // Employees can only read students assigned to them.
      allow read: if isSignedIn() && (isUserAdmin() || isDepartment() || resource.data.employeeId == getUserData().civilId);
      
      // Any authenticated user can create a student.
      allow create: if isSignedIn();

      // An admin, department user, or the assigned employee can update a student.
      allow update: if isSignedIn() && (isUserAdmin() || isDepartment() || resource.data.employeeId == getUserData().civilId);

      // Only admins can delete students.
      allow delete: if isUserAdmin();
    }
    
    match /approved_universities/{universityId} {
      allow read: if isSignedIn();
      allow write: if isUserAdmin() || isDepartment();
    }

    match /application_questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isUserAdmin();
    }

    match /shared_documents/{documentId} {
      allow read: if isSignedIn();
      allow write: if isUserAdmin() || isDepartment();
    }

    match /request_types/{requestTypeId} {
      allow read: if isSignedIn();
      allow write: if isUserAdmin();
    }
    
    match /resource_links/{linkId} {
      allow read: if isSignedIn();
      allow write: if isUserAdmin() || isDepartment();
    }
    
    match /upcoming_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isUserAdmin();
    }
    
    match /users/{userId}/personal_todos/{todoId} {
      allow read, write: if isOwner(userId);
    }
    
    match /tasks/{taskId} {
      allow get: if isUserAdmin() || isDepartment() || (isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.recipientId == request.auth.uid));
      allow list: if isUserAdmin() || isDepartment() ||
        (isSignedIn() && request.query.where.authorId == request.auth.uid) ||
        (isSignedIn() && request.query.where.recipientId == request.auth.uid) ||
        (isSignedIn() && request.query.where.recipientId == 'all');
      allow create: if isSignedIn();
      allow update: if isUserAdmin() || isDepartment() || (isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.recipientId == request.auth.uid));
      allow delete: if isUserAdmin();
    }

    match /chats/{studentId}/messages/{messageId} {
      // Users can only access chats for students they have access to.
      allow read, write: if isSignedIn() && (
        isUserAdmin() || isDepartment() || (getUserData().civilId == get(/databases/$(database)/documents/students/$(studentId)).data.employeeId)
      );
    }

    match /time_logs/{logId} {
        allow read: if isUserAdmin();
        allow write: if isSignedIn();
    }
  }
}
