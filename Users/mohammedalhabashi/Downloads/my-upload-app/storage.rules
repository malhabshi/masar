rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isUserAdmin() {
      return getUserData().role == 'admin';
    }
    
    function isDepartment() {
      return getUserData().role == 'department';
    }

    // Student documents can be uploaded and read by any authenticated user.
    // The previous complex rule was causing permission errors.
    match /students/{studentId}/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Shared documents can be written by admin/dept and read by any authenticated user.
    match /shared_documents/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isUserAdmin() || isDepartment());
    }

  }
}
