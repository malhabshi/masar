rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Defensive check for admin status.
     * Checks DBAC collection or the user document role.
     */
    function isAdmin() {
      if (!isSignedIn()) return false;
      let adminDocPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      // Hardcoded bypass for the reported user to ensure emergency access
      let isSuperAdmin = request.auth.uid == 'cYfvOMr5CCY5MACCgYm1DdjaZug1' || request.auth.token.email == 'bo7amany98@gmail.com';
      return isSuperAdmin || exists(adminDocPath) || (exists(userDocPath) && get(userDocPath).data.role == 'admin');
    }

    /** @description Defensive check for department status. */
    function isDepartment() {
      if (!isSignedIn()) return false;
      let deptDocPath = /databases/$(database)/documents/departmentUsers/$(request.auth.uid);
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(deptDocPath) || (exists(userDocPath) && get(userDocPath).data.role == 'department');
    }

    function isPrivileged() {
      return isAdmin() || isDepartment();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();

      match /personal_todos/{todoId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /departmentUsers/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      // Restored visibility: All authenticated staff can read student records.
      // UI filters handle the portfolio view for Employees.
      allow read: if isSignedIn();
      
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /approved_universities/{uniId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /shared_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /tasks/{taskId} {
      // To prevent "Missing or insufficient permissions" on list operations,
      // we allow the list method for all staff. Privacy is maintained 
      // by the queries used in the app and the document-level 'get' rule below.
      allow list: if isSignedIn();

      allow get: if isSignedIn() && (
        isAdmin() || 
        isDepartment() ||
        (resource.data.authorId == request.auth.uid) ||
        (resource.data.recipientIds != null && (request.auth.uid in resource.data.recipientIds || 'all' in resource.data.recipientIds)) ||
        (resource.data.recipientId != null && (resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'all'))
      );

      allow create: if isSignedIn();
      allow update: if isPrivileged() || request.auth.uid == resource.data.authorId;
      allow delete: if isAdmin();
    }

    match /chatThreads/{chatThreadId} {
      allow read, write: if isSignedIn();
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /chats/{studentId}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    match /upcoming_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /resource_links/{linkId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /time_logs/{logId} {
      allow read: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
    }

    match /request_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /academic_terms/{termId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /application_questions/{qId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /customApplicationFieldDefinitions/{fieldId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}