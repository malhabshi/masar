
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRole(role) {
      return getUserData().role == role;
    }

    function isOneOfRoles(roles) {
      return getUserData().role in roles;
    }

    // Check if a user has access to a specific student's data.
    // Access is granted to admins, department users, and the assigned employee.
    function hasStudentAccess(studentId) {
      // This function requires that the client provides the studentId
      if (!exists(/databases/$(database)/documents/students/$(studentId))) {
        return false;
      }
      let student = get(/databases/$(database)/documents/students/$(studentId)).data;
      let user = getUserData();
      return user.role in ['admin', 'department'] || 
             student.employeeId == user.civilId ||
             (user.role == 'student' && user.studentId == studentId);
    }

    // --- Collection Rules ---

    // Allow users to read/write their own personal_todos
    match /users/{userId}/personal_todos/{todoId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Users collection - custom rules for admin vs regular users
    match /users/{userId} {
      // Admins can read all profiles. Employees/Depts can read other employee/dept/admin profiles.
      // Students can only read their own profile.
      allow read: if request.auth != null && (
        isOneOfRoles(['admin', 'department', 'employee']) ||
        request.auth.uid == userId
      );
      
      // Admins can create/edit anyone.
      // Employees can create student users for their assigned students.
      // Users can edit their own profile, but cannot change their role.
      allow create: if request.auth != null && (
        isRole('admin') ||
        (isRole('employee') && request.resource.data.role == 'student')
      );
      allow update: if request.auth != null && (
        isRole('admin') ||
        (request.auth.uid == userId && !('role' in request.resource.data))
      );
      allow delete: if request.auth != null && isRole('admin');
    }
    
    // Tasks collection rules
    match /tasks/{taskId} {
      // Read is allowed for admins, departments, sender, recipient, or if it's a broadcast task ('all').
      allow read: if request.auth != null && (
        isOneOfRoles(['admin', 'department']) ||
        resource.data.authorId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid ||
        resource.data.recipientId == 'all'
      );
      // Create is allowed if the author is the current user.
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      // Update is allowed by admins, departments, the author, or the recipient.
      allow update: if request.auth != null && (
        isOneOfRoles(['admin', 'department']) ||
        resource.data.authorId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
      // Delete is restricted to admins to prevent accidental data loss.
      allow delete: if request.auth != null && isRole('admin');
    }
    
    // Students collection rules
    match /students/{studentId} {
      // LIST logic
      allow list: if request.auth != null && (
        isOneOfRoles(['admin', 'department']) ||
        // Allow querying assigned students
        (isRole('employee') && request.query.employeeId == getUserData().civilId) ||
        // Allow querying own created students (allows unassigned pool access)
        (isRole('employee') && request.query.createdBy == request.auth.uid)
      );

      // GET logic
      allow get: if request.auth != null && (
        isOneOfRoles(['admin', 'department']) ||
        (isRole('student') && getUserData().studentId == studentId) ||
        (resource.data.employeeId != null && resource.data.employeeId == getUserData().civilId) ||
        (resource.data.createdBy == request.auth.uid)
      );
      
      // WRITE logic
      allow write: if request.auth != null && (
        isOneOfRoles(['admin', 'department']) ||
        (resource.data.employeeId != null && resource.data.employeeId == getUserData().civilId) ||
        (resource.data.createdBy == request.auth.uid && resource.data.employeeId == null)
      );
    }

    // Approved universities - admins and dept can write, all can read
    match /approved_universities/{universityId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        isOneOfRoles(['admin', 'department']);
    }
    
    // Other global collections
    match /application_questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isRole('admin');
    }
    // Chat messages are nested under a student, so access is tied to student access.
    match /databases/{database}/documents/chats/{studentId}/messages/{messageId} {
      allow read, write: if request.auth != null && hasStudentAccess(studentId);
    }
    match /upcoming_events/{eventId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isOneOfRoles(['admin', 'department']));
    }
    match /shared_documents/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isOneOfRoles(['admin', 'department']);
    }
    match /request_types/{requestTypeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isRole('admin');
    }
    match /resource_links/{linkId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isOneOfRoles(['admin', 'department']);
    }

    // Restrict time logs to the employee and give read-only access to admins.
    match /time_logs/{logId} {
      allow create: if request.auth != null && 
        request.resource.data.employeeId == request.auth.uid;
      
      // Admins can read any log for reporting. Employees can read their own.
      allow read: if request.auth != null && (isRole('admin') || resource.data.employeeId == request.auth.uid);

      // Employees can only update/delete their own logs.
      allow update, delete: if request.auth != null && resource.data.employeeId == request.auth.uid;
    }
  }
}
