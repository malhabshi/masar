
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * UNIAPPLY HUB SECURITY RULES - EMERGENCY RECOVERY VERSION
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if user is an admin. 
     * Fallback: Checks both the dedicated DBAC collection AND the user's document role for safety.
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        // Emergency Super Admin Fallback (the user who reported the error)
        request.auth.uid == 'bbkDS193aqcaAJS6M6GkjWFgFTr1'
      );
    }

    /** @description Checks if user is in a department. Fallback included. */
    function isDepartment() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/departmentUsers/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'department'
      );
    }

    function isPrivileged() {
      return isAdmin() || isDepartment();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();

      match /personal_todos/{todoId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /departmentUsers/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      // EMERGENCY: Restore read access for all staff to confirm data existence
      allow read: if isSignedIn();
      
      allow create: if isPrivileged() || (isSignedIn() && request.resource.data.employeeId == getUserData().civilId);
      
      allow update: if isPrivileged() || (isSignedIn() && getUserData().civilId == resource.data.employeeId);
      
      allow delete: if isAdmin();
    }

    match /universityApplications/{applicationId} {
      allow read: if isSignedIn();
      allow create: if isPrivileged() || (isSignedIn() && request.resource.data.assignedToEmployeeId == getUserData().civilId);
      allow update: if isPrivileged() || (isSignedIn() && getUserData().civilId == resource.data.assignedToEmployeeId);
      allow delete: if isAdmin();
    }

    match /documents/{documentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isPrivileged() || isOwner(resource.data.authorId);
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.authorId == request.auth.uid ||
        request.auth.uid in resource.data.recipientIds ||
        'all' in resource.data.recipientIds ||
        (isDepartment() && 'dept:' + getUserData().department in resource.data.recipientIds)
      );
      allow create: if isSignedIn();
      allow update: if isPrivileged() || request.auth.uid == resource.data.authorId;
      allow delete: if isAdmin();
    }

    match /chats/{studentId} {
      allow read, write: if isSignedIn();
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /chatThreads/{chatThreadId} {
      allow read, write: if isSignedIn();
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /customApplicationFieldDefinitions/{fieldId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /upcoming_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /shared_documents/{documentId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /request_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /resource_links/{linkId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /time_logs/{logId} {
      allow read: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
    }
    
    match /approved_universities/{uniId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /academic_terms/{termId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
  }
}
