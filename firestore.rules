
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Robust check for admin status.
     * Checks DBAC collection first, falls back to the user's role field.
     */
    function isAdmin() {
      if (!isSignedIn()) return false;
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
             userDoc.role == 'admin' ||
             request.auth.uid == 'bbkDS193aqcaAJS6M6GkjWFgFTr1';
    }

    /** @description Checks if user is in a department. */
    function isDepartment() {
      if (!isSignedIn()) return false;
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return exists(/databases/$(database)/documents/departmentUsers/$(request.auth.uid)) ||
             userDoc.role == 'department';
    }

    function isPrivileged() {
      return isAdmin() || isDepartment();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();

      match /personal_todos/{todoId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /departmentUsers/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      // Admins and Department staff can see all students
      // Employees see students assigned to them via Civil ID
      allow read: if isPrivileged() || (isSignedIn() && (resource.data.employeeId == getUserData().civilId || resource.data.createdBy == request.auth.uid));
      
      // Employees can create unassigned students or students for themselves
      allow create: if isPrivileged() || isSignedIn();
      
      // Only privileged staff or the assigned employee can update
      allow update: if isPrivileged() || (isSignedIn() && getUserData().civilId == resource.data.employeeId);
      
      allow delete: if isAdmin();
    }

    match /universityApplications/{applicationId} {
      allow read: if isPrivileged() || (isSignedIn() && resource.data.assignedToEmployeeId == getUserData().civilId);
      allow create: if isSignedIn();
      allow update: if isPrivileged() || (isSignedIn() && getUserData().civilId == resource.data.assignedToEmployeeId);
      allow delete: if isAdmin();
    }

    match /documents/{documentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isPrivileged() || isOwner(resource.data.authorId);
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.authorId == request.auth.uid ||
        request.auth.uid in resource.data.recipientIds ||
        'all' in resource.data.recipientIds ||
        (isDepartment() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         'dept:' + get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department in resource.data.recipientIds)
      );
      allow create: if isSignedIn();
      allow update: if isPrivileged() || request.auth.uid == resource.data.authorId;
      allow delete: if isAdmin();
    }

    match /chats/{studentId} {
      allow read, write: if isSignedIn();
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /chatThreads/{chatThreadId} {
      allow read, write: if isSignedIn();
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /customApplicationFieldDefinitions/{fieldId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /upcoming_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /shared_documents/{documentId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /request_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /resource_links/{linkId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /time_logs/{logId} {
      allow read: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
    }
    
    match /approved_universities/{uniId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /academic_terms/{termId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
  }
}
