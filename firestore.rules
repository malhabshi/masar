rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read/write their own personal_todos
    match /users/{userId}/personal_todos/{todoId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Users collection - custom rules for admin vs regular users
    match /users/{userId} {
      // Anyone can read all users (for lookups)
      allow read: if request.auth != null;
      
      // Users can write their own document
      // Admins can write any user document
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    // Tasks collection - all authenticated users
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
    
    // Students collection - read/write for admin/dept/assigned employee
    match /students/{studentId} {
      allow read, write: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'department'] ||
        resource.data.employeeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.civilId
      );
    }
    
    // Approved universities - admins and dept can write, all can read
    match /approved_universities/{universityId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'department'];
    }
    
    // Applications - all authenticated users
    match /applications/{applicationId} {
      allow read, write: if request.auth != null;
    }

    // Other global collections
    match /application_questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /chats/{studentId}/messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    match /upcoming_events/{eventId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /shared_documents/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'department'];
    }
    match /request_types/{requestTypeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /resource_links/{linkId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'department'];
    }
    match /time_logs/{logId} {
      allow read, write: if request.auth != null;
    }
  }
}
