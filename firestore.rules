rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Defensive check for admin status.
     * Checks DBAC collection or the user document role.
     */
    function isAdmin() {
      if (!isSignedIn()) return false;
      let adminDoc = /databases/$(database)/documents/admins/$(request.auth.uid);
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(adminDoc) || (exists(userDoc) && get(userDoc).data.role == 'admin');
    }

    /** @description Defensive check for department status. */
    function isDepartment() {
      if (!isSignedIn()) return false;
      let deptDoc = /databases/$(database)/documents/departmentUsers/$(request.auth.uid);
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(deptDoc) || (exists(userDoc) && get(userDoc).data.role == 'department');
    }

    function isPrivileged() {
      return isAdmin() || isDepartment();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();

      match /personal_todos/{todoId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /departmentUsers/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      // Staff can see all students.
      allow read: if isSignedIn();
      
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /approved_universities/{uniId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /shared_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /tasks/{taskId} {
      // For list operations, the rule must allow the query result set.
      // This logic must exactly match the filters used in the client query.
      allow list: if isSignedIn() && (
        isAdmin() || 
        isDepartment() ||
        (resource.data.authorId == request.auth.uid) ||
        (resource.data.recipientIds != null && (request.auth.uid in resource.data.recipientIds || 'all' in resource.data.recipientIds)) ||
        (resource.data.recipientId != null && (resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'all'))
      );

      allow get: if isSignedIn() && (
        isAdmin() || 
        isDepartment() ||
        (resource.data.authorId == request.auth.uid) ||
        (resource.data.recipientIds != null && (request.auth.uid in resource.data.recipientIds || 'all' in resource.data.recipientIds)) ||
        (resource.data.recipientId != null && (resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'all'))
      );

      allow create: if isSignedIn();
      allow update: if isPrivileged() || request.auth.uid == resource.data.authorId;
      allow delete: if isAdmin();
    }

    match /chats/{studentId}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    match /upcoming_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /resource_links/{linkId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /time_logs/{logId} {
      allow read: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
    }

    match /request_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /academic_terms/{termId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /application_questions/{qId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}