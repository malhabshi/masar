
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Safe check for admin status.
     * Checks DBAC collection OR the hardcoded bypass.
     */
    function isAdmin() {
      if (!isSignedIn()) return false;
      let adminDocPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      
      // Hardcoded bypass for the reported users to ensure emergency access
      // Included corrected UID variant for malhabshi@q8sf.com (handling I/l and 0/O confusion)
      let isSuperAdmin = request.auth.uid == 'cYfvOMr5CCY5MACCgYm1DdjaZug1' || 
                         request.auth.uid == 'IZr1zv5ePQb0bKNVXS4xGjERmE62' ||
                         request.auth.uid == 'lZr1zv5ePQbObKNVXS4xGjERmE62' ||
                         request.auth.token.email == 'bo7amany98@gmail.com' ||
                         request.auth.token.email == 'malhabshi@q8sf.com';
                         
      return isSuperAdmin || exists(adminDocPath) || (exists(userDocPath) && get(userDocPath).data.role == 'admin');
    }

    /** @description Safe check for department status. */
    function isDepartment() {
      if (!isSignedIn()) return false;
      let deptDocPath = /databases/$(database)/documents/departmentUsers/$(request.auth.uid);
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(deptDocPath) || (exists(userDocPath) && get(userDocPath).data.role == 'department');
    }

    function isPrivileged() {
      return isAdmin() || isDepartment();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();

      match /personal_todos/{todoId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /departmentUsers/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      // All staff can read student records. UI filters handle portfolio views.
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /approved_universities/{uniId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /shared_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /tasks/{taskId} {
      // Allow LIST if signed in. We rely on GET and Query filters for security.
      allow list: if isSignedIn();

      // GET rules define individual document access
      allow get: if isSignedIn() && (
        isAdmin() ||
        isDepartment() ||
        (resource.data.authorId == request.auth.uid) ||
        (resource.data.recipientIds != null && (request.auth.uid in resource.data.recipientIds || 'all' in resource.data.recipientIds)) ||
        (resource.data.recipientId != null && (resource.data.recipientId == request.auth.uid || request.auth.uid == 'all'))
      );

      allow create: if isSignedIn();
      allow update: if isPrivileged() || request.auth.uid == resource.data.authorId;
      allow delete: if isAdmin();
    }

    match /chatThreads/{chatThreadId} {
      allow read, write: if isSignedIn();
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /chats/{studentId}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    match /upcoming_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /resource_links/{linkId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /time_logs/{logId} {
      allow read: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
    }

    match /request_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /academic_terms/{termId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /application_questions/{qId} {
      allow read, write, list: if isAdmin();
    }
    
    match /customApplicationFieldDefinitions/{fieldId} {
      allow read, write, list: if isAdmin();
    }
  }
}
