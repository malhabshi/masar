rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * UNIAPPLY HUB SECURITY RULES
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Validates if the user's UID exists in the admin collection or matches the specific requested UID. */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.uid == 'IZr1zv5ePQb0bKNVXS4xGjERmE62'
      );
    }

    /** @description Validates if the user's UID exists in the department users collection. */
    function isDepartment() {
      return isSignedIn() && exists(/databases/$(database)/documents/departmentUsers/$(request.auth.uid));
    }

    /** @description Helper for users with elevated administrative privileges. */
    function isPrivileged() {
      return isAdmin() || isDepartment();
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Retrieves the user's data from their profile document. */
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- Rules ---

    /** @description Access rules for User profiles and personal data. */
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      match /personal_todos/{todoId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /admins/{userId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }
    match /departmentUsers/{userId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }

    /** @description Access rules for Student profiles. Restricted fields for intake. */
    match /students/{studentId} {
      allow read, list: if isSignedIn();
      
      allow create: if isPrivileged() || (isSignedIn() && request.resource.data.employeeId == getUserData().civilId);
      
      allow update: if resource != null && (
        isPrivileged() || 
        (isSignedIn() && getUserData().civilId == resource.data.employeeId)
      );
      
      allow delete: if isPrivileged();
    }

    /** @description Rules for student university applications. */
    match /universityApplications/{applicationId} {
      allow get, list: if isSignedIn();
      allow create: if isPrivileged() || (isSignedIn() && request.resource.data.assignedToEmployeeId == getUserData().civilId);
      allow update: if isPrivileged() || (isSignedIn() && getUserData().civilId == resource.data.assignedToEmployeeId);
      allow delete: if isPrivileged();
    }

    match /documents/{documentId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isPrivileged() || isOwner(resource.data.authorId);
    }

    match /tasks/{taskId} {
      allow get, list: if isSignedIn();
      allow create: if isPrivileged() || isSignedIn();
      allow update: if isPrivileged() || isOwner(resource.data.recipientId) || isOwner(resource.data.authorId);
      allow delete: if isPrivileged();
    }

    /** @description Rules for internal chats and messages. */
    match /chats/{studentId} {
      allow read, write: if isSignedIn();
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /chatThreads/{chatThreadId} {
      allow read, write: if isSignedIn();
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /customApplicationFieldDefinitions/{fieldId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isPrivileged();
    }

    match /upcoming_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /shared_documents/{documentId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /request_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /resource_links/{linkId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /time_logs/{logId} {
      allow read: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isPrivileged() || resource.data.employeeId == request.auth.uid);
    }
    
    match /approved_universities/{uniId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /academic_terms/{termId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
  }
}
