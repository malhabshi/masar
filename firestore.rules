rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Defensive check for admin status.
     * Uses multiple fallback checks to ensure resilient access.
     */
    function isAdmin() {
      if (!isSignedIn()) return false;
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
             (userDoc != null && userDoc.data.role == 'admin') ||
             request.auth.token.email == 'malhabshi@masarkw.com' ||
             request.auth.uid == 'bbkDS193aqcaAJS6M6GkjWFgFTr1';
    }

    /** @description Defensive check for department status. */
    function isDepartment() {
      if (!isSignedIn()) return false;
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return exists(/databases/$(database)/documents/departmentUsers/$(request.auth.uid)) ||
             (userDoc != null && userDoc.data.role == 'department');
    }

    function isPrivileged() {
      return isAdmin() || isDepartment();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();

      match /personal_todos/{todoId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /departmentUsers/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      // Admins and Department staff see all. 
      // Employees see assigned (via civilId) or created.
      allow read: if isPrivileged() || (isSignedIn() && (
        resource.data.employeeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.civilId || 
        resource.data.createdBy == request.auth.uid
      ));
      
      allow create: if isSignedIn();
      allow update: if isPrivileged() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.civilId == resource.data.employeeId);
      allow delete: if isAdmin();
    }

    match /approved_universities/{uniId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /shared_documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /tasks/{taskId} {
      // Robust FIFO-compatible read rules
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.authorId == request.auth.uid ||
        request.auth.uid in resource.data.recipientIds ||
        'all' in resource.data.recipientIds ||
        (isDepartment() && 'dept:' + get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department in resource.data.recipientIds)
      );
      allow create: if isSignedIn();
      allow update: if isPrivileged() || request.auth.uid == resource.data.authorId;
      allow delete: if isAdmin();
    }

    match /chats/{studentId}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    match /upcoming_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /resource_links/{linkId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /time_logs/{logId} {
      allow read: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
    }

    match /request_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /academic_terms/{termId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
  }
}
