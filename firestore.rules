rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * UNIAPPLY HUB SECURITY RULES
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Validates if the user's UID exists in the admin collection or matches the specific requested UID. */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.uid == 'IZr1zv5ePQb0bKNVXS4xGjERmE62'
      );
    }

    /** @description Validates if the user's UID exists in the department users collection. */
    function isDepartment() {
      return isSignedIn() && exists(/databases/$(database)/documents/departmentUsers/$(request.auth.uid));
    }

    /** @description Helper for users with elevated administrative privileges. */
    function isPrivileged() {
      return isAdmin() || isDepartment();
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if a document exists and the user is the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Rules ---

    /**
     * @description Access rules for the User profile collection.
     */
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if false;

      /** @description Fixed: Added rules for personal todos subcollection */
      match /personal_todos/{todoId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /admins/{userId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }
    match /departmentUsers/{userId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }

    /**
     * @description Access rules for the Student entity.
     * Updated: Allows all authenticated users to read student data.
     * Restricted: Only Admin/Dept can update academicIntake fields.
     */
    match /students/{studentId} {
      // REQUIREMENT: Allow all authenticated users to read student data
      allow get, list: if isSignedIn();
      
      allow create: if isPrivileged() || (isSignedIn() && request.resource.data.employeeId == request.auth.uid);
      
      // REQUIREMENT: Only Admin/Dept can update academicIntake fields.
      allow update: if resource != null && (
        isPrivileged() || 
        (isOwner(resource.data.employeeId) && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['academicIntakeSemester', 'academicIntakeYear']))
      );
      
      allow delete: if isPrivileged();
    }

    /**
     * @description Access rules for University Applications.
     */
    match /universityApplications/{applicationId} {
      allow get, list: if isSignedIn();
      allow create: if isPrivileged() || (isSignedIn() && request.resource.data.assignedToEmployeeId == request.auth.uid);
      allow update: if isPrivileged() || isExistingOwner(resource.data.assignedToEmployeeId);
      allow delete: if isPrivileged();
    }

    match /documents/{documentId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uploadedByUserId == request.auth.uid;
      allow update, delete: if isPrivileged() || isExistingOwner(resource.data.uploadedByUserId);
    }

    /**
     * @description Access rules for Tasks.
     */
    match /tasks/{taskId} {
      allow get, list: if isSignedIn();
      allow create: if isPrivileged();
      allow update: if isPrivileged() || isExistingOwner(resource.data.assignedToUserId);
      allow delete: if isPrivileged();
    }

    match /chatThreads/{chatThreadId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isPrivileged() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow delete: if isPrivileged();

      match /messages/{messageId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isPrivileged() || (resource != null && isOwner(resource.data.senderId));
      }
    }

    match /customApplicationFieldDefinitions/{fieldId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isPrivileged();
    }
  }
}